PORT=3000
NODE_ENV=production

# JWT — Générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REMPLACER_PAR_UN_SECRET_LONG_ET_ALEATOIRE

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_VOTRE_CLE_STRIPE_SECRETE
STRIPE_PUBLISHABLE_KEY=pk_live_VOTRE_CLE_PUBLIQUE_STRIPE
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_SECRET_WEBHOOK_STRIPE

# Plateforme
PLATFORM_FEE_PCT=0.15
PLATFORM_NAME=Luxury Concierge
PLATFORM_URL=https://votre-domaine.com

# Base de données (optionnel — mémoire par défaut en dev)
# DATABASE_URL=postgresql://user:password@localhost:5432/luxuryconcierge

# Email (optionnel)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre@email.com
# SMTP_PASS=votre_mot_de_passe_app

# Langues activées (comma-separated)
SUPPORTED_LANGUAGES=fr,en,zh,es,ar
DEFAULT_LANGUAGE=fr
